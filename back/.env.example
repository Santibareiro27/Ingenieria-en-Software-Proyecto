# Conexion a MariaDB / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sgso
DB_USER=root
DB_PASSWORD=
# Poner true solo si la base esta en la nube y exige conexion cifrada (ej. Aiven)
DB_SSL=false

# Autenticacion (login)
JWT_SECRET=cambiar_por_una_clave_larga_y_secreta
JWT_SEGUNDOS=28800

# Origen permitido para CORS (el frontend). En desarrollo: http://localhost:5173
CORS_ORIGIN=http://localhost:5173
